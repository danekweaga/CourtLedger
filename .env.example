# Client-side (Vite — exposed in the browser build)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-side (Vercel API routes only — do NOT prefix with VITE_)
# Set these in Vercel → Project Settings → Environment Variables
YOUTUBE_DATA_API_KEY=your_youtube_data_api_v3_key
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional
# YOUTUBE_NBA_CHANNEL_ID=UCWJ2lWNubArHWmf3FIHbfcQ
