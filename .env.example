# Client-side (Vite — exposed in the browser build)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-side (Vercel API routes only — do NOT prefix with VITE_)
# Set these in Vercel → Project Settings → Environment Variables
YOUTUBE_DATA_API_KEY=your_youtube_data_api_v3_key
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
CRON_SECRET=generate_a_long_random_secret

# Optional
# YOUTUBE_NBA_CHANNEL_ID=UCWJ2lWNubArHWmf3FIHbfcQ

# Integration tests (optional — use a dedicated Supabase project)
# SUPABASE_TEST_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_TEST_ANON_KEY=your_supabase_anon_key
# SUPABASE_TEST_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase Edge Function secrets (set in Supabase Dashboard, not Vercel)
# CRON_SECRET=generate_a_long_random_secret
# BALLDONTLIE_API_KEY=your_balldontlie_api_key
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
